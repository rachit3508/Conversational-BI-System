# Copy to .env and adjust for your machine.
# Uses Windows / trusted authentication -- no username or password required.

# Named instance form: localhost\INSTANCENAME  (a bare "localhost" only works
# when a default MSSQLSERVER instance exists)
DB_SERVER=localhost\SQLEXPRESS
DB_NAME=your_database

# Run `Get-OdbcDriver` in PowerShell to see which drivers are installed.
DB_DRIVER=ODBC Driver 18 for SQL Server

# Driver 18 defaults to Encrypt=yes; local instances usually lack a trusted
# certificate, so this must stay "yes" for localhost development.
DB_TRUST_SERVER_CERTIFICATE=yes
